---
import { languageSupport } from '../../data/languages';

interface Props {
  variant?: 'landing' | 'docs';
}

const { variant = 'landing' } = Astro.props;
const isLanding = variant === 'landing';

const statusLabels = {
  supported: 'Supported',
  developing: 'Developing',
  planning: 'Planning',
} as const;
---

<div class:list={['language-grid', { 'language-grid--docs': !isLanding }]}>
  {languageSupport.map((language) => (
    <a class="language-card" href={`/docs/languages/${language.slug}/`}>
      <div class="language-card__header">
        <div>
          <span class="language-card__short">{language.shortName}</span>
          <h3>{language.name}</h3>
        </div>
        <span class:list={['language-card__status', `language-card__status--${language.status}`]}>
          {statusLabels[language.status]}
        </span>
      </div>
      <p class="language-card__summary">{language.summary}</p>
      <p class="language-card__support">{language.currentSupport}</p>
    </a>
  ))}
</div>

<style>
  .language-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.6rem;
  }

  .language-grid--docs {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1rem;
  }

  .language-card {
    display: grid;
    gap: 0.85rem;
    padding: 1.15rem;
    border: 1px solid rgba(47, 54, 49, 0.12);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.72);
    color: inherit;
    text-decoration: none;
    box-shadow: 0 12px 30px rgba(31, 39, 35, 0.08);
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .language-card:hover {
    transform: translateY(-2px);
    border-color: rgba(17, 94, 89, 0.3);
    box-shadow: 0 18px 34px rgba(31, 39, 35, 0.1);
  }

  .language-card__header {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .language-card__short {
    display: inline-block;
    margin-bottom: 0.35rem;
    color: #56645d;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .language-card h3 {
    margin: 0;
    font-size: 1.18rem;
    line-height: 1.1;
  }

  .language-card__status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .language-card__status--supported {
    background: rgba(15, 118, 110, 0.12);
    color: #0f766e;
  }

  .language-card__status--developing {
    background: rgba(196, 107, 55, 0.14);
    color: #a14d1f;
  }

  .language-card__status--planning {
    background: rgba(86, 100, 93, 0.12);
    color: #56645d;
  }

  .language-card__summary,
  .language-card__support {
    margin: 0;
    line-height: 1.6;
  }

  .language-card__summary {
    color: inherit;
  }

  .language-card__support {
    color: #56645d;
    font-size: 0.95rem;
  }

  @media (max-width: 900px) {
    .language-grid,
    .language-grid--docs {
      grid-template-columns: 1fr;
    }
  }
</style>
